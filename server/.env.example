# ── Server Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.

PORT=5001
NODE_ENV=development

# PostgreSQL connection string
# For local dev without Docker:
#   DATABASE_URL=postgres://postgres:<your-password>@localhost:5432/studyroom
# For Docker (docker-compose sets this automatically):
DATABASE_URL=postgres://postgres:password@localhost:5432/studyroom

# JWT secret — use a long random string in production
JWT_SECRET=this_is_a_super_secret_key_change_in_production

# Frontend URL (used for CORS and password-reset email links)
CLIENT_URL=http://localhost:5173

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized JavaScript origins: http://localhost:5173
# 5. Copy the Client ID below
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
