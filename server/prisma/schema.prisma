// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// MODULE 1: Users, Authentication & Gamification (BE1)
// ============================================================

model User {
  id             Int       @id @default(autoincrement())
  name           String
  email          String    @unique
  password       String    @db.Text
  avatarUrl      String?   @map("avatar_url")
  role           String    @default("free") // 'free', 'pro', 'admin'
  streakCount    Int       @default(0)      @map("streak_count")
  lastActiveAt   DateTime? @db.Timestamptz  @map("last_active_at")
  createdAt               DateTime  @default(now())  @db.Timestamptz @map("created_at")
  updatedAt               DateTime  @default(now())  @updatedAt @db.Timestamptz @map("updated_at")

  // Password reset (hashed token stored, never plaintext)
  resetPasswordToken      String?   @map("reset_password_token")
  resetPasswordExpire     DateTime? @db.Timestamptz @map("reset_password_expire")

  // BE3 Day 4: Pair Coding Sessions
  hostedSessions  PairSession[] @relation("HostSessions")
  guestSessions   PairSession[] @relation("GuestSessions")
  pairCursors     PairCursor[]

  // BE1: Auth & Gamification Relations
  oauthAccounts   OAuthAccount[]
  subscriptions   Subscription[]
  userBadges      UserBadge[]
  friendshipsA    Friendship[] @relation("UserAFriendships")
  friendshipsB    Friendship[] @relation("UserBFriendships")

  // BE2: Study Rooms & Real-time Relations
  ownedRooms      StudyRoom[]  @relation("RoomOwner")
  roomMembers     RoomMember[]
  chatMessages    ChatMessage[]

  // BE3: Problems & Submissions Relations
  submissions     Submission[]
  discussions     Discussion[]
  contestEntries  ContestParticipant[]

  // Mock Interviews
  mockInterviews MockInterview[]
  
  // Study Plans Progress
  studyPlanProgress UserStudyPlanProgress[]
  weeklyChallengeProgress UserWeeklyChallengeProgress[]

  @@map("users")
}

model OAuthAccount {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           Int      @map("user_id")
  provider         String   // 'google', 'github'
  providerClientId String   @map("provider_client_id")
  createdAt        DateTime @default(now()) @db.Timestamptz @map("created_at")

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerClientId])
  @@map("oauth_accounts")
}

model Subscription {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             Int       @map("user_id")
  status             String    // 'active', 'canceled', 'unpaid'
  planType           String    @map("plan_type") // 'monthly', 'yearly'
  currentPeriodStart DateTime  @db.Timestamptz @map("current_period_start")
  currentPeriodEnd   DateTime  @db.Timestamptz @map("current_period_end")
  createdAt          DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @db.Timestamptz @map("updated_at")

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Badge {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String
  iconUrl     String      @map("icon_url")
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    Int      @map("user_id")
  badgeId   String   @db.Uuid @map("badge_id")
  earnedAt  DateTime @default(now()) @db.Timestamptz @map("earned_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Friendship {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAId   Int      @map("user_a_id")
  userBId   Int      @map("user_b_id")
  status    String   @default("pending") // 'pending', 'accepted', 'blocked'
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")

  userA     User     @relation("UserAFriendships", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("UserBFriendships", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@map("friendships")
}

// ============================================================
// MODULE 2: Real-time Study Rooms & Productivity (BE2)
// ============================================================

model StudyRoom {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String   @unique
  ownerId    Int      @map("owner_id")
  isPrivate  Boolean  @default(false) @map("is_private")
  roomType   String   @default("study") // 'study', 'pair_programming', 'mock_interview'
  createdAt  DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @db.Timestamptz @map("updated_at")

  owner      User         @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members    RoomMember[]
  messages   ChatMessage[]
  tasks      RoomTask[]
  whiteboard WhiteboardSession?

  @@map("study_rooms")
}

model RoomMember {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId   String    @db.Uuid @map("room_id")
  userId   Int       @map("user_id")
  isOnline Boolean   @default(false) @map("is_online")
  socketId String?   @map("socket_id")
  joinedAt DateTime  @default(now()) @db.Timestamptz @map("joined_at")

  room     StudyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("room_members")
}

model ChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId    String   @db.Uuid @map("room_id")
  userId    Int      @map("user_id")
  message   String
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")

  room      StudyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model RoomTask {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId      String   @db.Uuid @map("room_id")
  title       String
  isCompleted Boolean  @default(false) @map("is_completed")
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")

  room        StudyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_tasks")
}

model WhiteboardSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId    String   @unique @db.Uuid @map("room_id")
  elements  Json     @default("[]")
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz @map("updated_at")

  room      StudyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("whiteboard_sessions")
}

// ============================================================
// MODULE 3: Problems, Contests & Discussions (BE3)
// ============================================================

model Problem {
  id             Int      @id @default(autoincrement())
  title          String   @unique
  slug           String   @unique
  description    String   @db.Text
  difficulty     String
  tags           String[]
  testCases      Json     @default("[]")    @map("test_cases")
  starterCode    Json     @default("{}")    @map("starter_code")
  isPremium      Boolean  @default(false) @map("is_premium")
  acceptanceRate Float    @default(0.0)   @map("acceptance_rate")
  createdAt      DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz @map("updated_at")

  // Mock Interview Relations
  mockInterviewProblems MockInterviewProblem[]
  mockInterviewResults  MockInterviewResult[]
  
  // Study Plan Relations
  studyPlanProblems StudyPlanProblem[]
  weeklyChallengeProblems WeeklyChallengeProblem[]
  
  // Existing Relations
  submissions     Submission[]
  discussions     Discussion[]
  contestProblems ContestProblem[]
  pairSessions    PairSession[]

  @@map("problems")
}

model Submission {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         Int      @map("user_id")
  problemId      Int      @map("problem_id")
  language       String
  code           String   @db.Text
  status         String   @default("pending")
  runtimeMs      Int?     @map("runtime_ms")
  memoryKb       Int?     @map("memory_kb")
  
  errorMessage   String?  @map("error_message")
  testResults    Json?    @map("test_results")
  submittedFrom  String?  @map("submitted_from")
  pairSessionId  String?  @map("pair_session_id") @db.Uuid
  
  createdAt      DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem        Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  pairSession    PairSession? @relation(fields: [pairSessionId], references: [id])

  @@map("submissions")
}

// ============================================================
// STUDY PLANS (BE3 Day 5/6)
// ============================================================

model StudyPlan {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String
  slug           String    @unique
  description    String    @db.Text
  difficulty     String    // 'beginner', 'intermediate', 'advanced', 'mixed'
  durationDays   Int       @map("duration_days")
  problemCount   Int       @map("problem_count")
  isPro          Boolean   @default(false) @map("is_pro")
  icon           String?   // emoji or icon name
  color          String?   // theme color
  createdAt      DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamptz @map("updated_at")

  // Relations
  userProgress   UserStudyPlanProgress[]
  planProblems   StudyPlanProblem[]

  @@map("study_plans")
}

model StudyPlanProblem {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId         String    @map("plan_id") @db.Uuid
  problemId      Int       @map("problem_id")
  dayNumber      Int       @map("day_number")
  orderIndex     Int       @default(0) @map("order_index")
  notes          String?   @db.Text

  plan           StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  problem        Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([planId, dayNumber, problemId])
  @@map("study_plan_problems")
}

model UserStudyPlanProgress {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         Int       @map("user_id")
  planId         String    @map("plan_id") @db.Uuid
  currentDay     Int       @default(1) @map("current_day")
  completedDays  Int[]     @default([]) @map("completed_days")
  startedAt      DateTime  @default(now()) @db.Timestamptz @map("started_at")
  completedAt    DateTime? @db.Timestamptz @map("completed_at")
  lastActivityAt DateTime  @default(now()) @db.Timestamptz @map("last_activity_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@map("user_study_plan_progress")
}

// ============================================================
// WEEKLY CHALLENGES (BE3 Day 6)
// ============================================================

model WeeklyChallenge {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  weekNumber     Int       @unique @map("week_number")
  startDate      DateTime  @db.Timestamptz @map("start_date")
  endDate        DateTime  @db.Timestamptz @map("end_date")
  theme          String?   // e.g., "Dynamic Programming Week", "Graph Week"
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @db.Timestamptz @map("created_at")

  problems       WeeklyChallengeProblem[]
  userProgress   UserWeeklyChallengeProgress[]

  @@map("weekly_challenges")
}

model WeeklyChallengeProblem {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challengeId    String    @map("challenge_id") @db.Uuid
  problemId      Int       @map("problem_id")
  dayNumber      Int       @map("day_number")  // 1-7
  orderIndex     Int       @default(0) @map("order_index")

  challenge      WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  problem        Problem        @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([challengeId, dayNumber])
  @@map("weekly_challenge_problems")
}

model UserWeeklyChallengeProgress {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         Int       @map("user_id")
  challengeId    String    @map("challenge_id") @db.Uuid
  completedDays  Int[]     @default([]) @map("completed_days")
  startedAt      DateTime  @default(now()) @db.Timestamptz @map("started_at")
  completedAt    DateTime? @db.Timestamptz @map("completed_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge      WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("user_weekly_challenge_progress")
}

// ============================================================
// MODULE 4: Mock Interview Mode (BE3 Day 5)
// ============================================================

model MockInterview {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        Int      @map("user_id")
  difficulty    String   // 'easy', 'medium', 'hard', 'mixed', 'random'
  status        String   @default("in_progress") // 'in_progress', 'completed', 'timeout'
  startedAt     DateTime @default(now()) @db.Timestamptz @map("started_at")
  completedAt   DateTime? @db.Timestamptz @map("completed_at")
  totalScore    Int?     @default(0) @map("total_score")
  isPro         Boolean  @default(false) @map("is_pro")
  weakTopics    String[] // Array of weak topics identified
  problemCount  Int      @default(3) @map("problem_count")
  
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problems      MockInterviewProblem[]
  results       MockInterviewResult[]

  @@map("mock_interviews")
}

model MockInterviewProblem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId   String   @map("interview_id") @db.Uuid
  problemId     Int      @map("problem_id")
  orderIndex    Int      @map("order_index")
  
  interview     MockInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  problem       Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([interviewId, orderIndex])
  @@map("mock_interview_problems")
}

model MockInterviewResult {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId   String   @map("interview_id") @db.Uuid
  problemId     Int      @map("problem_id")
  code          String   @db.Text
  passed        Boolean
  runtimeMs     Int?     @map("runtime_ms")
  memoryKb      Int?     @map("memory_kb")
  score         Int      @default(0)
  submittedAt   DateTime @default(now()) @db.Timestamptz @map("submitted_at")
  
  interview     MockInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  problem       Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("mock_interview_results")
}

// ============================================================
// PAIR CODING SESSIONS (BE3 Day 4)
// ============================================================

model PairSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomCode    String   @unique @map("room_code")
  problemId   Int?     @map("problem_id")
  hostId      Int      @map("host_id")
  guestId     Int?     @map("guest_id")
  status      String   @default("waiting") // waiting, active, ended
  language    String   @default("python")
  currentCode String?  @map("current_code") @db.Text
  createdAt   DateTime @default(now()) @db.Timestamptz @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz @map("updated_at")
  submissions  Submission[]

  // Relations
  problem     Problem?      @relation(fields: [problemId], references: [id], onDelete: Cascade)
  host        User         @relation("HostSessions", fields: [hostId], references: [id])
  guest       User?        @relation("GuestSessions", fields: [guestId], references: [id])
  cursors     PairCursor[]

  @@map("pair_sessions")
}

model PairCursor {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String   @db.Uuid @map("session_id")
  userId       Int      @map("user_id")
  lineNumber   Int      @default(1) @map("line_number")
  columnNumber Int      @default(1) @map("column_number")
  color        String   @default("#7F77DD")
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamptz @map("updated_at")

  session      PairSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("pair_cursors")
}

// ============================================================
// CONTESTS (BE3)
// ============================================================

model Contest {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String
  startTime    DateTime             @db.Timestamptz @map("start_time")
  endTime      DateTime             @db.Timestamptz @map("end_time")
  createdAt    DateTime             @default(now()) @db.Timestamptz @map("created_at")
  problems     ContestProblem[]
  participants ContestParticipant[]

  @@map("contests")
}

model ContestProblem {
  contestId String @db.Uuid @map("contest_id")
  problemId Int    @map("problem_id")
  points    Int    @default(100)

  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([contestId, problemId])
  @@map("contest_problems")
}

model ContestParticipant {
  contestId  String @db.Uuid @map("contest_id")
  userId     Int    @map("user_id")
  totalScore Int    @default(0) @map("total_score")

  contest    Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([contestId, userId])
  @@map("contest_participants")
}

model Discussion {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  problemId Int      @map("problem_id")
  userId    Int      @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")

  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("discussions")
}

// ============================================================
// MODULE 5: Global Infrastructure, Leaderboard & Audits (BE4)
// ============================================================

model LeaderboardEntry {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     Int      @map("user_id")
  period     String
  score      Int      @default(0)
  rank       Int?
  computedAt DateTime @default(now()) @db.Timestamptz @map("computed_at")

  @@unique([userId, period])
  @@map("leaderboard_entries")
}

model AnalyticsEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    Int?     @map("user_id")
  eventName String   @map("event_name")
  properties Json?
  createdAt DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@index([eventName])
  @@index([createdAt(sort: Desc)])
  @@map("analytics_events")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    Int      @map("actor_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  metaData   Json?    @map("metadata")
  createdAt  DateTime @default(now()) @db.Timestamptz @map("created_at")

  @@map("audit_logs")
}