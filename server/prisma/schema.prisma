generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      Int                           @id @default(autoincrement())
  name                    String
  email                   String                        @unique
  password                String
  avatarUrl               String?                       @map("avatar_url")
  role                    String                        @default("free")
  streakCount             Int                           @default(0) @map("streak_count")
  lastActiveAt            DateTime?                     @map("last_active_at") @db.Timestamptz(6)
  totalStudyHours         Float                         @default(0.0) @map("total_study_hours")
  focusSessionsCount      Int                           @default(0) @map("focus_sessions_count")
  problemsSolved          Int                           @default(0) @map("problems_solved")
  problemsAttempted       Int                           @default(0) @map("problems_attempted")
  acceptanceRate          Float                         @default(0.0) @map("acceptance_rate")
  pomodorosToday          Int                           @default(0) @map("pomodoros_today")
  pomodorosTotal          Int                           @default(0) @map("pomodoros_total")
  solvedThisMonth         Int                           @default(0) @map("solved_this_month")
  solvedAllTime           Int                           @default(0) @map("solved_all_time")
  studyHoursThisWeek      Float                         @default(0.0) @map("study_hours_this_week")
  activityActiveDays      Int                           @default(0) @map("activity_active_days")
  longestStreak           Int                           @default(0) @map("longest_streak")
  totalSessions           Int                           @default(0) @map("total_sessions")
  studyHoursToday         Float                         @default(0.0) @map("study_hours_today")
  subjectMix              Json                          @default("{}") @map("subject_mix")
  studyHoursLog           Json                          @default("[]") @map("study_hours_log")
  heatmapData             Json                          @default("[]") @map("heatmap_data")
  createdAt               DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  resetPasswordToken      String?                       @map("reset_password_token")
  resetPasswordExpire     DateTime?                     @map("reset_password_expire") @db.Timestamptz(6)
  chatMessages            ChatMessage[]
  contestEntries          ContestParticipant[]
  discussions             Discussion[]
  friendshipsA            Friendship[]                  @relation("UserAFriendships")
  friendshipsB            Friendship[]                  @relation("UserBFriendships")
  mockInterviews          MockInterview[]
  oauthAccounts           OAuthAccount[]
  pairCursors             PairCursor[]
  guestSessions           PairSession[]                 @relation("GuestSessions")
  hostedSessions          PairSession[]                 @relation("HostSessions")
  roomMembers             RoomMember[]
  ownedRooms              StudyRoom[]                   @relation("RoomOwner")
  studySessions           StudySession[]
  submissions             Submission[]
  subscriptions           Subscription[]
  userBadges              UserBadge[]
  studyPlanProgress       UserStudyPlanProgress[]
  weeklyChallengeProgress UserWeeklyChallengeProgress[]

  @@map("users")
}

model OAuthAccount {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           Int      @map("user_id")
  provider         String
  providerClientId String   @map("provider_client_id")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerClientId])
  @@map("oauth_accounts")
}

model Subscription {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             Int      @map("user_id")
  status             String
  planType           String   @map("plan_type")
  currentPeriodStart DateTime @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd   DateTime @map("current_period_end") @db.Timestamptz(6)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Badge {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String
  iconUrl     String      @map("icon_url")
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   Int      @map("user_id")
  badgeId  String   @map("badge_id") @db.Uuid
  earnedAt DateTime @default(now()) @map("earned_at") @db.Timestamptz(6)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Friendship {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAId   Int      @map("user_a_id")
  userBId   Int      @map("user_b_id")
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  userA     User     @relation("UserAFriendships", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("UserBFriendships", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@map("friendships")
}

model StudyRoom {
  id         String             @id
  name       String
  slug       String             @unique
  ownerId    Int                @map("owner_id")
  isPrivate  Boolean            @default(false) @map("is_private")
  roomType   String             @default("study")
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  messages   ChatMessage[]
  members    RoomMember[]
  tasks      RoomTask[]
  owner      User               @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  whiteboard WhiteboardSession?

  @@map("study_rooms")
}

model RoomMember {
  id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId   String    @map("room_id")
  userId   Int       @map("user_id")
  isOnline Boolean   @default(false) @map("is_online")
  socketId String?   @map("socket_id")
  joinedAt DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  room     StudyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("room_members")
}

model ChatMessage {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId    String    @map("room_id")
  userId    Int       @map("user_id")
  message   String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  room      StudyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model RoomTask {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId      String    @map("room_id")
  title       String
  isCompleted Boolean   @default(false) @map("is_completed")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  room        StudyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_tasks")
}

model WhiteboardSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId    String    @unique @map("room_id")
  elements  Json      @default("[]")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  room      StudyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("whiteboard_sessions")
}

model Problem {
  id                      Int                      @id @default(autoincrement())
  title                   String                   @unique
  slug                    String                   @unique
  description             String
  difficulty              String
  tags                    String[]
  testCases               Json                     @default("[]") @map("test_cases")
  starterCode             Json                     @default("{}") @map("starter_code")
  isPremium               Boolean                  @default(false) @map("is_premium")
  acceptanceRate          Float                    @default(0.0) @map("acceptance_rate")
  constraints             String?
  hints                   String[]                 @default([])
  leetcodeUrl             String?                  @map("leetcode_url")
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  contestProblems         ContestProblem[]
  discussions             Discussion[]
  mockInterviewProblems   MockInterviewProblem[]
  mockInterviewResults    MockInterviewResult[]
  pairSessions            PairSession[]
  studyPlanProblems       StudyPlanProblem[]
  submissions             Submission[]
  weeklyChallengeProblems WeeklyChallengeProblem[]

  @@map("problems")
}

model Submission {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        Int          @map("user_id")
  problemId     Int          @map("problem_id")
  language      String
  code          String
  status        String       @default("pending")
  runtimeMs     Int?         @map("runtime_ms")
  memoryKb      Int?         @map("memory_kb")
  errorMessage  String?      @map("error_message")
  testResults   Json?        @map("test_results")
  submittedFrom String?      @map("submitted_from")
  pairSessionId String?      @map("pair_session_id")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  pairSession   PairSession? @relation(fields: [pairSessionId], references: [id])
  problem       Problem      @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("submissions")
}

model StudyPlan {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  slug         String                  @unique
  description  String
  difficulty   String
  durationDays Int                     @map("duration_days")
  problemCount Int                     @map("problem_count")
  isPro        Boolean                 @default(false) @map("is_pro")
  icon         String?
  color        String?
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  planProblems StudyPlanProblem[]
  userProgress UserStudyPlanProgress[]

  @@map("study_plans")
}

model StudyPlanProblem {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId     String    @map("plan_id") @db.Uuid
  problemId  Int       @map("problem_id")
  dayNumber  Int       @map("day_number")
  orderIndex Int       @default(0) @map("order_index")
  notes      String?
  plan       StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  problem    Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([planId, dayNumber, problemId])
  @@map("study_plan_problems")
}

model UserStudyPlanProgress {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         Int       @map("user_id")
  planId         String    @map("plan_id") @db.Uuid
  currentDay     Int       @default(1) @map("current_day")
  completedDays  Int[]     @default([]) @map("completed_days")
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  lastActivityAt DateTime  @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  plan           StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@map("user_study_plan_progress")
}

model WeeklyChallenge {
  id           String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  weekNumber   Int                           @unique @map("week_number")
  startDate    DateTime                      @map("start_date") @db.Timestamptz(6)
  endDate      DateTime                      @map("end_date") @db.Timestamptz(6)
  theme        String?
  isActive     Boolean                       @default(true) @map("is_active")
  createdAt    DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  userProgress UserWeeklyChallengeProgress[]
  problems     WeeklyChallengeProblem[]

  @@map("weekly_challenges")
}

model WeeklyChallengeProblem {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  challengeId String          @map("challenge_id") @db.Uuid
  problemId   Int             @map("problem_id")
  dayNumber   Int             @map("day_number")
  orderIndex  Int             @default(0) @map("order_index")
  challenge   WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  problem     Problem         @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([challengeId, dayNumber])
  @@map("weekly_challenge_problems")
}

model UserWeeklyChallengeProgress {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        Int             @map("user_id")
  challengeId   String          @map("challenge_id") @db.Uuid
  completedDays Int[]           @default([]) @map("completed_days")
  startedAt     DateTime        @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt   DateTime?       @map("completed_at") @db.Timestamptz(6)
  challenge     WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("user_weekly_challenge_progress")
}

model MockInterview {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       Int                    @map("user_id")
  difficulty   String
  status       String                 @default("in_progress")
  startedAt    DateTime               @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt  DateTime?              @map("completed_at") @db.Timestamptz(6)
  totalScore   Int?                   @default(0) @map("total_score")
  isPro        Boolean                @default(false) @map("is_pro")
  weakTopics   String[]
  problemCount Int                    @default(3) @map("problem_count")
  problems     MockInterviewProblem[]
  results      MockInterviewResult[]
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mock_interviews")
}

model MockInterviewProblem {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId String        @map("interview_id") @db.Uuid
  problemId   Int           @map("problem_id")
  orderIndex  Int           @map("order_index")
  interview   MockInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  problem     Problem       @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([interviewId, orderIndex])
  @@map("mock_interview_problems")
}

model MockInterviewResult {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId String        @map("interview_id") @db.Uuid
  problemId   Int           @map("problem_id")
  code        String
  passed      Boolean
  runtimeMs   Int?          @map("runtime_ms")
  memoryKb    Int?          @map("memory_kb")
  score       Int           @default(0)
  submittedAt DateTime      @default(now()) @map("submitted_at") @db.Timestamptz(6)
  interview   MockInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  problem     Problem       @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("mock_interview_results")
}

model PairSession {
  id          String       @id
  roomCode    String       @unique @map("room_code")
  problemId   Int?         @map("problem_id")
  hostId      Int          @map("host_id")
  guestId     Int?         @map("guest_id")
  status      String       @default("waiting")
  language    String       @default("python")
  currentCode String?      @map("current_code")
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  cursors     PairCursor[]
  guest       User?        @relation("GuestSessions", fields: [guestId], references: [id])
  host        User         @relation("HostSessions", fields: [hostId], references: [id])
  problem     Problem?     @relation(fields: [problemId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("pair_sessions")
}

model PairCursor {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String      @map("session_id")
  userId       Int         @map("user_id")
  lineNumber   Int         @default(1) @map("line_number")
  columnNumber Int         @default(1) @map("column_number")
  color        String      @default("#7F77DD")
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  session      PairSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("pair_cursors")
}

model Contest {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String
  startTime    DateTime             @map("start_time") @db.Timestamptz(6)
  endTime      DateTime             @map("end_time") @db.Timestamptz(6)
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  participants ContestParticipant[]
  problems     ContestProblem[]

  @@map("contests")
}

model ContestProblem {
  contestId String  @map("contest_id") @db.Uuid
  problemId Int     @map("problem_id")
  points    Int     @default(100)
  contest   Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@id([contestId, problemId])
  @@map("contest_problems")
}

model ContestParticipant {
  contestId  String  @map("contest_id") @db.Uuid
  userId     Int     @map("user_id")
  totalScore Int     @default(0) @map("total_score")
  contest    Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([contestId, userId])
  @@map("contest_participants")
}

model Discussion {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  problemId Int      @map("problem_id")
  userId    Int      @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("discussions")
}

model LeaderboardEntry {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     Int      @map("user_id")
  period     String
  score      Int      @default(0)
  rank       Int?
  computedAt DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  @@unique([userId, period])
  @@map("leaderboard_entries")
}

model AnalyticsEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     Int?     @map("user_id")
  eventName  String   @map("event_name")
  properties Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventName])
  @@index([createdAt(sort: Desc)])
  @@map("analytics_events")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    Int      @map("actor_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  metaData   Json?    @map("metadata")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("audit_logs")
}

model StudySession {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          Int      @map("user_id")
  roomId          String?  @map("room_id")
  roomName        String   @default("Study Room") @map("room_name")
  durationMinutes Int      @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_sessions")
}
